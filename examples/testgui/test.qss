
QMenuBar {
background-color: #333;
color: white;
}

QMenu {
background-color: #333;
color: white;
}

QMenu::item:selected {
background-color: #555;
}

/* Specific Style for actionPower */
QAction#actionPower {
font-weight: bold;
color: #FF5555; /* Red color */
}

QAction#actionPower:hover {
background-color: #880000;
color: white;
}


QAction#actionPower {
	background-color: #ffcccc;
	color: red;
	font-weight: bold;
	padding: 5px 10px;
}


QPushButton {
	background-color: #f0f0f0;
	border-style: solid;
	border-width: 2px;
	border-radius: 5px;
	border-color: #ffffff #999999 #999999 #ffffff;
	padding: 4px;
}

QPushButton:pressed {
	background-color: #dcdcdc;
	border-style: solid;
	border-width: 2px;
	border-radius: 5px;
	border-color: #999999 #ffffff #ffffff #999999; /* Top Right Bottom Left */
	padding: 4px;
}

QPushButton#estop_pb {
	background-color: #55ff7f;
	border-style: solid;
	border-color: #000000;
	border-width: 2px;
	border-radius: 6px;
	padding: 2;
}

QPushButton#estop_pb:checked {
	color: #ffff00;
	background-color: #ff0000;
}

QPushButton#power_pb {
	background-color: #55ff7f;
	border-style: solid;
	border-color: #000000;
	border-width: 2px;
	border-radius: 6px;
	padding: 2;

}


QPushButton#power_pb:checked {
	color: #ffff00;
	background-color: #ff0000;

}

QPushButton#power_pb:disabled {
	color: #a3a3a3;
	background-color: #f3f3f3;
	border-color: #b1b1b1;

}


